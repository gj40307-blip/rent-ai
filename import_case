if __name__ == "__main__":
    print(f"🚀 啟動「租賃合約條款檢測」資料生成引擎 (Model: {MODEL})")
    print(f"📚 知識庫：共 {len(CONTRACT_RULES)} 條核心租賃法規")
    print(f"🎯 目標設定：每條生成 {CASES_PER_RULE} 筆 (含 {int(TRAP_RATIO*100)}% 違法陷阱，{100-int(TRAP_RATIO*100)}% 合法範例)")
    
    comprehensive_dataset = []
    case_counter = 800 # 用來產生 case_001, case_002...
    
    for rule in tqdm(CONTRACT_RULES, desc="法規掃描與生成中"):
        for _ in range(CASES_PER_RULE):
            # 決定生成合法還是陷阱條款
            is_trap = random.random() < TRAP_RATIO
            
            entry = generate_contract_clause(rule, is_trap=is_trap)
            
            if entry:
                # 補上 ID，並格式化為 case_XXX
                entry["id"] = f"case_{case_counter:03d}"
                comprehensive_dataset.append(entry)
                case_counter += 1
            
            # 暫停一下避免 Ollama 過載
            time.sleep(0.1)
            
    # 存檔
    if comprehensive_dataset:
        with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
            json.dump(comprehensive_dataset, f, ensure_ascii=False, indent=2)
            
        print(f"\n✅ 任務完成！共生成 {len(comprehensive_dataset)} 筆高品質合約測試資料。")
        print(f"💾 檔案已儲存：{OUTPUT_FILE}")
        print("💡 這些資料包含了你的專題所需要的特定 JSON 格式，可以直接餵給你們的系統進行測試！")
    else:
        print("❌ 生成失敗，請檢查 Ollama (11434 port) 是否正常啟動，或模型名稱是否正確。")