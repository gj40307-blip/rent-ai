# ================= 🚀 核心生成邏輯 =================

def generate_contract_clause(rule_data, is_trap=True):
    """
    生成單一合約條款測試案例，符合專題需要的 JSON 格式。
    (已修改為：白話文書面合約口吻)
    """
    
    source_name = rule_data["source"]
    article_name = rule_data["article"]
    article_content = rule_data["content"]
    
    # 動態調整提示詞 (修改為白話文書面設定)
    if is_trap:
        clause_style = "【白話文寫成的霸王條款】（文字淺顯易懂，但內容實際上違反法規、規避責任或亂收費用）"
        legal_status = "不合法" 
    else:
        clause_style = "【白話文寫成的合法條款】（文字淺顯易懂，且內容完全符合法規、保障雙方權益）"
        legal_status = "合法"

    prompt = f"""
    你是一位台灣租屋法律專家。請根據以下【法規依據】，撰寫一段「白話文版本」的租賃契約條文。

    【法規依據】：{article_name}
    【法規內容】：{article_content}
    
    【你的任務】：
    請生成一段 {clause_style} 的合約條款。
    語氣必須維持「書面的合約規定格式」，但要使用「一般大眾都能輕鬆閱讀的白話文」（約 50-100 字）。
    
    ★ 嚴格禁止偏題（非常重要）：
    生成的「條款內容」必須【100% 緊扣】上方提供的法規主題！
    例如：法規如果是在講「通知」，條文就只能跟「寄信、Line、聯絡地址」有關，絕對不可以扯到「電費、修繕、押金」等無關的主題！
    
    ★ 詞彙替換建議（請依上下文自然轉換，不要硬塞無關的詞）：
    1. 務必將「承租人」改成「房客」、「出租人」改成「房東」、「租賃住宅」改成「房屋或房間」。
    2. 若法條中有提到「不可歸責於」，請改用白話文「非房客的錯」或「天災意外」。
    3. 若法條有提到「終止契約」，請改用「解約」或「退租」。
    4. 說明欄位必須邏輯清晰：請明確區分條款中「哪一句合法」與「哪一句違法」，不可以把法定正確的規則說成是違法的。

    請生成一個 JSON 格式的回應，嚴格遵守以下欄位與名稱：
    {{
      "條款內容": "模擬出來的白話文合約條款",
      "類型": "這個條款涉及的主題（請根據法規內容精準命名，如：通知方式、押金上限等）",
      "是否合法": "根據你的設定，填寫『合法』、『不合法』或『不合法/顯失公平』",
      "說明": "詳細解釋為什麼這個條款合法或不合法。如果是陷阱，請明確指出違反了法規的哪一句話。"
    }}
    
    注意：
    1. 不要輸出 "id"、"來源"、"依據條文" 這三個欄位，Python 程式會自動補上。
    2. 請直接回傳 JSON，不要包含任何 markdown 標記 (例如 ```json)。確保格式可以被 Python 的 json.loads() 直接解析。
    """

    payload = {
        "model": MODEL,
        "messages": [{"role": "user", "content": prompt}],
        "stream": False,
        "options": {"temperature": 0.6 if is_trap else 0.3} # 稍微調低溫度，讓語氣保持合約的嚴肅感
    }

    try:
        response = requests.post(OLLAMA_API, json=payload, timeout=90)
        if response.status_code == 200:
            result_text = response.json()['message']['content']
            
            # 清理 JSON 字串 (防呆機制)
            if "```json" in result_text:
                result_text = result_text.split("```json")[1].split("```")[0]
            elif "```" in result_text:
                result_text = result_text.split("```")[1].split("```")[0]
            
            data = json.loads(result_text.strip())
            
            # 組合最終你需要的格式
            return {
                "id": "", # 稍後在外層迴圈填入
                "條款內容": data.get("條款內容", ""),
                "類型": data.get("類型", ""),
                "是否合法": data.get("是否合法", legal_status),
                "來源": source_name,
                "依據條文": article_name,
                "說明": data.get("說明", "")
            }
    except Exception as e:
        # 發生錯誤時回傳 None
        return None
    return None

